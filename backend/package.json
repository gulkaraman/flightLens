{
  "name": "bilet-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "scrape": "node dist/cli/scrape.js",
    "dev:scrape": "ts-node src/cli/scrape.ts",
    "selfcheck": "node dist/cli/selfcheck.js",
    "dev:selfcheck": "ts-node src/cli/selfcheck.ts",
    "scrape:obilet": "ts-node src/cli/obiletSmoke.ts",
    "smoke": "ts-node src/cli/smoke.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "puppeteer": "^23.11.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "eslint": "^9.16.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vitest": "^1.6.0"
  }
}
